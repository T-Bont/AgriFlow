VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Public token only (pk.*). Create at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.your-public-mapbox-token

# Supabase Edge Function secrets (set in Supabase project secrets, not in Vite env)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# app.settings.supabase_url=https://your-project.supabase.co
# app.settings.service_role_key=your-service-role-key
